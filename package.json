{
  "name": "@didrod2539/calforge",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Generate valid .ics calendar files and 'Add to Calendar' links (Google, Outlook, Yahoo, Apple) entirely locally — no third-party service, no tracking, no API key. RFC 5545 correct, zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ics",
    "icalendar",
    "ical",
    "add-to-calendar",
    "calendar",
    "rfc5545",
    "google-calendar",
    "outlook",
    "event",
    "vevent",
    "calendar-link",
    "zero-dependency",
    "cli"
  ],
  "author": "didrod205 (https://github.com/didrod205)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/didrod205/calforge.git"
  },
  "bugs": {
    "url": "https://github.com/didrod205/calforge/issues"
  },
  "homepage": "https://didrod205.github.io/calforge/",
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "bin": {
    "calforge": "./dist/cli.js"
  }
}
